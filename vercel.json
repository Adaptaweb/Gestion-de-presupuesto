{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://gestion-presupuesto-backend.railway.app/api/$1" },
    { "source": "/oauth2callback", "destination": "https://gestion-presupuesto-backend.railway.app/oauth2callback" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
