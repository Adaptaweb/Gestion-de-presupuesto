# Variable de entorno para JWT Secret
# Cambia este valor a una cadena aleatoria y segura antes de desplegar en producción
# Puedes generar una con: openssl rand -base64 32
JWT_SECRET=gestion-presupuesto-secret-2026-prod
PORT=3000
NODE_ENV=production
GMAIL_CLIENT_ID=tu_client_id_aqui
GMAIL_CLIENT_SECRET=tu_client_secret_aqui
GMAIL_REDIRECT_URI=http://localhost:3000/oauth2callback

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:tu_contraseña@db.xxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui

# Gemini AI (necesaria para el frontend en producción)
VITE_GEMINI_API_KEY=tu_gemini_api_key_aqui

# Web Push (VAPID) — para notificaciones push PWA
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=tu_vapid_public_key_aqui
VAPID_PRIVATE_KEY=tu_vapid_private_key_aqui
VAPID_SUBJECT=mailto:tu-email@dominio.com
